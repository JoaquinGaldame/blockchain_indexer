NODE_ENV=development
LOG_LEVEL=info
HOST=0.0.0.0
PORT=3000

# Native development DATABASE_URL.
# Docker Compose overrides this inside the app container to use the `postgres` service hostname.
# If the database password contains special characters, URL-encode only the password.
# Example password: p@ss#word:123
# Encoded password: p%40ss%23word%3A123
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/blockchain_indexer?schema=public

# Replace with a real Sepolia RPC URL before enabling the indexer.
ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_API_KEY
INDEXER_NETWORK=sepolia
INDEXER_ENABLED=true
INDEXER_BATCH_SIZE=1000
INDEXER_CONFIRMATIONS=2
INDEXER_POLL_INTERVAL_MS=12000

# Optional bootstrap input for inserting/updating contracts from config.
# Runtime reads active contracts from PostgreSQL; this is only a convenience seed path.
# ABI paths are resolved from the project root.
CONTRACT_BOOTSTRAP_CONFIG=[{"name":"SampleErc20","address":"0x0000000000000000000000000000000000000000","network":"sepolia","chainId":11155111,"abiPath":"src/contracts/abi/SampleErc20.json","startBlock":0,"isActive":true}]

# Optional Docker Compose overrides.
# These are read by docker-compose.yml, not by the native Node.js process.
DOCKER_INDEXER_ENABLED=false
DOCKER_ETHEREUM_RPC_URL=https://sepolia.infura.io/v3/YOUR_API_KEY
